      {"id": "streak", "params": {"max_freeze": 2, "milestones": [7, 30, 100]}},
      {"id": "tier", "params": {"tiers": [
        {"id": "green", "name": "Green", "threshold_xp": 500, "perks": ["birthday_drink"]},
        {"id": "gold", "name": "Gold", "threshold_xp": 5000, "perks": ["mobile_order_skip", "double_stars"]}
      ]}},
      {"id": "smartquests", "params": {"refresh_daily": true, "count": 3}},
