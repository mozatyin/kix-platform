        "actions": [{"module": "progression", "method": "award_xp", "params": {"amount": 10}}]
      },
      {
        "name": "Refresh daily quests at login",
        "trigger_event": "user_login",
        "actions": [{"module": "smartquests", "method": "generate", "params": {"count": 3}}]
      }
    ],
    "metadata": {
      "source": "Starbucks Rewards 2009-present",
      "original_users": "30M+",
      "key_metric": "revenue_lift",
      "key_metric_value": "+11% YoY"
    }
  },
